# ════════════════════════════════════════════════════════════════
#   HireIQ — Root .gitignore (Python/FastAPI backend only)
# ════════════════════════════════════════════════════════════════


# ── SECRETS & ENV (NEVER COMMIT) ────────────────────────────────
.env
.env.*
!.env.example
hiring-agent/.env
hiring-agent/.env.*
!hiring-agent/.env.example


# ── LOGS (contain applicant PII) ────────────────────────────────
logs/
*.log
*.log.zip
*.log.gz
hiring-agent/logs/


# ── PYTHON ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
wheels/
MANIFEST


# ── VIRTUAL ENVIRONMENTS ─────────────────────────────────────────
.venv/
venv/
env/
ENV/
hiring-agent/.venv/


# ── PYTHON TOOLING ───────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.cover
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
dmypy.json


# ── DATABASES / VECTOR STORES ────────────────────────────────────
*.db
*.sqlite
*.sqlite3
chroma_data/
faiss_index/


# ── CERTIFICATES & KEYS ──────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
*.der


# ── AI TOOLING ───────────────────────────────────────────────────
.claude/


# ── INTERNAL DOCS (not for public repo) ──────────────────────────
system-design.html
project_handoff_context.md
PROJECT_CONTEXT.md


# ── OS ───────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
Desktop.ini


# ── EDITOR / IDE ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.history/


# ── TEMP ─────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej
tmp/
temp/
